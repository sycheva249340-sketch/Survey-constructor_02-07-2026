      "title": "Основной",
      "questions": [
        {
          "id": "naming_1",
          "type": "open",
          "title": "Ассоциации",
          "text": "Какие мысли и ассоциации возникают у вас, когда вы видите это название?",
          "comment": "",
          "settings": {}
        },
        {
          "id": "naming_2",
          "type": "scale",
          "title": "Привлекательность",
          "text": "Насколько вам нравится данное название?",
          "settings": { "scaleMin": 1, "scaleMax": 5 }
        },
        {
          "id": "naming_3",
          "type": "scale",
          "title": "Понятность",
          "text": "Насколько вам понятно данное название?",
