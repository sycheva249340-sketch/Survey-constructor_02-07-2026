          "settings": { "scaleMin": 1, "scaleMax": 5 }
        },
        {
          "id": "naming_7",
          "type": "scale",
          "title": "Воспользоваться",
          "text": "Насколько вероятно, что вы бы воспользовались данным предложением с таким названием?",
